{
  "name": "art-design-pro",
  "version": "0.0.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=8.8.0"
  },
  "scripts": {
    "dev": "vite --open",
    "build": "rimraf pysrc/static/dist && vite build",
    "build-check": "vue-tsc --noEmit && vite build",
    "build:desktop": "pnpm build && node scripts/build-desktop.mjs",
    "build:desktop:only": "node scripts/build-desktop.mjs",
    "build:desktop:onedir": "pnpm build && node scripts/build-desktop.mjs onedir",
    "build:desktop:onedir:only": "node scripts/build-desktop.mjs onedir",
    "build:desktop:win": "node scripts/build-desktop.mjs windows",
    "build:desktop:mac": "node scripts/build-desktop.mjs macos",
    "serve": "vite preview",
    "backend:client": "cd pysrc && uv run python main.py local",
    "backend:service": "cd pysrc && uv run python main.py remote",
    "backend:self-use": "cd pysrc && uv run python main.py self_use",
    "desktop:client": "cd pysrc && uv run python desktop.py local",
    "desktop:service": "cd pysrc && uv run python desktop.py remote",
    "desktop:self-use": "cd pysrc && uv run python desktop.py self_use",
    "desktop:client:dev": "cd pysrc && set \"PYWEBVIEW_DEV_URL=http://localhost:3006\" && uv run python desktop.py local",
    "desktop:self-use:dev": "cd pysrc && set \"PYWEBVIEW_DEV_URL=http://localhost:3006\" && uv run python desktop.py self_use",
    "desktop:pywebview": "pnpm desktop:client",
    "desktop:pywebview:dev": "pnpm desktop:client:dev",
    "lint": "eslint",
    "fix": "eslint --fix",
    "lint:prettier": "prettier --write \"**/*.{js,cjs,ts,json,tsx,css,less,scss,vue,html,md}\"",
    "lint:stylelint": "stylelint  \"**/*.{css,scss,vue}\" --fix",
    "lint:lint-staged": "lint-staged",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{cjs,json,jsonc}": [
      "prettier --write"
    ],
    "*.vue": [
      "eslint --fix",
      "stylelint --fix --allow-empty-input",
      "prettier --write"
    ],
    "*.{html,htm}": [
      "prettier --write"
    ],
    "*.{scss,css,less}": [
      "stylelint --fix --allow-empty-input",
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "prettier --write"
    ],
    "*.{yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.8",
    "@dagrejs/dagre": "^1.1.8",
    "@element-plus/icons-vue": "^2.3.2",
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/markdown-it": "^14.1.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.0",
    "@vue/reactivity": "^3.5.21",
    "@vueuse/core": "^13.9.0",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "next",
    "axios": "^1.12.2",
    "codemirror": "^6.0.2",
    "crypto-js": "^4.2.0",
    "driver.js": "^1.4.0",
    "echarts": "^6.0.0",
    "element-plus": "^2.11.2",
    "file-saver": "^2.0.5",
    "github-markdown-css": "^5.8.1",
    "highlight.js": "^11.10.0",
    "lottie-web": "^5.13.0",
    "markdown-it": "^14.1.0",
    "md-editor-v3": "^6.1.1",
    "mermaid": "^11.12.3",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "ohash": "^2.0.11",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.3.0",
    "primeicons": "^7.0.0",
    "qrcode.vue": "^3.6.0",
    "tailwindcss": "^4.1.14",
    "vue": "^3.5.21",
    "vue-draggable-plus": "^0.6.0",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.5.1",
    "vue3-lottie": "^3.3.1",
    "xgplayer": "^3.0.20",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@eslint/js": "^9.9.1",
    "@types/node": "^24.0.5",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/compiler-sfc": "^3.0.5",
    "commitizen": "^4.3.0",
    "cz-git": "^1.11.1",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-vue": "^9.27.0",
    "globals": "^15.9.0",
    "husky": "^9.1.5",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.2",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.81.0",
    "stylelint": "^16.20.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^4.6.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^36.0.1",
    "terser": "^5.36.0",
    "tsx": "^4.20.3",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.9.0",
    "unplugin-auto-import": "^20.2.0",
    "unplugin-element-plus": "^0.10.0",
    "unplugin-vue-components": "^29.1.0",
    "vite": "^7.1.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vue-demi": "^0.14.9",
    "vue-img-cutter": "^3.0.5",
    "vue-tsc": "~2.1.6"
  }
}
