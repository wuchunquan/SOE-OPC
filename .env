# 【通用】环境变量

#  版本号
VITE_VERSION = 3.0.1

# 端口号
VITE_PORT = 3006

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# 权限模式【 frontend 前端模式 / backend 后端模式 】
VITE_ACCESS_MODE = frontend

# 跨域请求时是否携带 Cookie（开启前需确保后端支持）
VITE_WITH_CREDENTIALS = false

# 是否打开路由信息
VITE_OPEN_ROUTE_INFO = false

# 锁屏加密密钥
VITE_LOCK_ENCRYPT_KEY = s3cur3k3y4adpro

# 是否为演示模式（演示模式下会显示数据安全提示）
VITE_DEMO_MODE = false
# AI Agent 功能开关（默认不启用）
VITE_ENABLE_AGENT = true

# 对象存储基础URL（用于产品介绍视频、语音、动画资源）
VITE_RESOURCE_BASE_URL = https://home132.tos-cn-beijing.volces.com/hzx

# 本地后端服务地址（Tauri 桌面端使用）
VITE_LOCAL_API_BASE_URL = http://127.0.0.1:8766

# 前端展示名称与桌面目录名称
VITE_APP_NAME = 一人国企·OPC
VITE_APP_DIR_NAME = 一人国企·OPC
